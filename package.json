{
  "name": "@viablkit/cli",
  "version": "0.1.2",
  "description": "Local development CLI for Viabl documentation",
  "main": "dist/index.js",
  "bin": {
    "viabl": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "check": "biome check .",
    "format": "biome format --write .",
    "format-and-check": "pnpm format && pnpm check",
    "deps": "pnpm dlx taze@latest -w",
    "deps:check": "pnpm dlx taze@latest",
    "deps:major": "pnpm dlx taze@latest major -w",
    "prepare": "husky",
    "commit": "git add . && git cz"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git",
      "useEmoji": true
    }
  },
  "keywords": [
    "docs",
    "documentation",
    "viabl",
    "cli",
    "mdx"
  ],
  "author": "Oj-washingtone",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Oj-washingtone/viabl-cli.git"
  },
  "homepage": "https://viabl.dev",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "tar-fs": "^3.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.3.5",
    "@types/tar-fs": "^2.0.4",
    "cz-git": "^1.12.0",
    "husky": "^9.1.7",
    "typescript": "^5.9.3"
  }
}
